<div class="container">
    <div class="page-header">
        <a href="/admin" style="color: var(--text-secondary); text-decoration: none; font-size: 14px;">← Назад в админ-панель</a>
        <h1 style="margin-top: 16px;">Модерация вакансий</h1>
    </div>

    <% if (vacancies.length === 0) { %>
        <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
                <path d="M9 5a2 2 0 002-2h2a2 2 0 002 2M9 5h6"/>
            </svg>
            <h3>Нет вакансий на модерации</h3>
            <p>Все вакансии проверены</p>
        </div>
    <% } else { %>
        <table class="table">
            <thead>
                <tr>
                    <th>Вакансия</th>
                    <th>Работодатель</th>
                    <th>Город</th>
                    <th>Статус</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% vacancies.forEach(v => { %>
                    <tr>
                        <td>
                            <strong><%= v.title %></strong><br>
                            <span style="color: var(--text-secondary); font-size: 13px;"><%= v.profession %></span>
                        </td>
                        <td>
                            <%= v.organization_name %><br>
                            <span style="color: var(--text-secondary); font-size: 13px;"><%= v.employer_email %></span>
                        </td>
                        <td><%= v.city %></td>
                        <td>
                            <% if (v.status === 'pending') { %>
                                <span class="badge badge-pending">На проверке</span>
                            <% } else if (v.status === 'approved') { %>
                                <span class="badge badge-approved">Одобрена</span>
                            <% } else { %>
                                <span class="badge badge-rejected">Отклонена</span>
                            <% } %>
                        </td>
                        <td><%= new Date(v.created_at).toLocaleDateString('ru-RU') %></td>
                        <td>
                            <% if (v.status === 'pending') { %>
                                <form action="/admin/vacancy/<%= v.id %>/status" method="POST" style="display: inline;">
                                    <input type="hidden" name="status" value="approved">
                                    <button type="submit" class="btn btn-sm btn-primary">✓</button>
                                </form>
                                <form action="/admin/vacancy/<%= v.id %>/status" method="POST" style="display: inline;">
                                    <input type="hidden" name="status" value="rejected">
                                    <button type="submit" class="btn btn-sm btn-secondary">✗</button>
                                </form>
                            <% } else { %>
                                <a href="/vacancies/<%= v.id %>" class="btn btn-sm btn-secondary" target="_blank">Просмотр</a>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>
