<div class="container">
    <div class="page-header">
        <a href="/admin" style="color: var(--text-secondary); text-decoration: none; font-size: 14px;">← Назад в админ-панель</a>
        <h1 style="margin-top: 16px;">Черный список работодателей</h1>
    </div>

    <div class="detail-section" style="margin-bottom: 24px;">
        <h2>Добавить в черный список</h2>
        <form action="/admin/blacklist/add" method="POST" style="display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;">
            <div class="form-group" style="flex: 1; min-width: 200px; margin-bottom: 0;">
                <label for="employer_id">Работодатель</label>
                <select id="employer_id" name="employer_id" class="form-control" required>
                    <option value="">Выберите работодателя</option>
                    <% employers.forEach(e => { %>
                        <option value="<%= e.id %>"><%= e.organization_name %> (<%= e.email %>)</option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group" style="flex: 2; min-width: 300px; margin-bottom: 0;">
                <label for="reason">Причина блокировки</label>
                <input type="text" id="reason" name="reason" class="form-control" placeholder="Например: мошенничество, спам...">
            </div>
            <button type="submit" class="btn btn-primary" style="height: 44px;">Заблокировать</button>
        </form>
    </div>

    <% if (blacklist.length === 0) { %>
        <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
            </svg>
            <h3>Черный список пуст</h3>
            <p>Нет заблокированных работодателей</p>
        </div>
    <% } else { %>
        <table class="table">
            <thead>
                <tr>
                    <th>Работодатель</th>
                    <th>ИНН</th>
                    <th>Причина</th>
                    <th>Дата блокировки</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% blacklist.forEach(b => { %>
                    <tr>
                        <td>
                            <strong><%= b.organization_name %></strong><br>
                            <span style="color: var(--text-secondary); font-size: 13px;"><%= b.email %></span>
                        </td>
                        <td><%= b.inn || '—' %></td>
                        <td><%= b.reason || 'Не указана' %></td>
                        <td><%= new Date(b.created_at).toLocaleDateString('ru-RU') %></td>
                        <td>
                            <% if (b.is_active) { %>
                                <form action="/admin/blacklist/remove" method="POST" style="display: inline;">
                                    <input type="hidden" name="id" value="<%= b.id %>">
                                    <button type="submit" class="btn btn-sm btn-primary">Разблокировать</button>
                                </form>
                            <% } else { %>
                                <span class="badge badge-rejected">Неактивен</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>
